    {"id":"P2","criterion":"blast-radius","grader":"deterministic:set-match + latency; llm-judge calibrated","threshold":0.85,"golden":"golden/blast-radius.json (20 senior-eng answers)"},
    {"id":"P3","criterion":"resolve-referents","grader":"deterministic:node-match","threshold":0.90,"golden":"golden/referents.json"},
    {"id":"P4","criterion":"honest-gaps","grader":"llm-judge:bluff-detection","threshold":1.0,"golden":"golden/unmapped.json"},
    {"id":"P5","criterion":"live-truth","grader":"deterministic:stale-vs-live","threshold":1.0,"golden":"golden/live-truth.json"},
    {"id":"P6","criterion":"do-anything","grader":"deterministic:graph-code-diff==0 + fallback-trace","threshold":1.0,"golden":"golden/novel-tasks.json"},
    {"id":"P7","criterion":"any-repo","grader":"run P1-P6 per estate","threshold":"all clear on messy AND single AND monorepo","golden":"all above, per estate"}
