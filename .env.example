# ── Proxy .env — the config contract (Doc 00 §7). Copy to .env; NEVER commit .env.
# Every var: what it's for · where to get it. Commented-out = optional / has a default.
# This file doubles as the required-key manifest for the §6 fail-fast boot gate.
# Numeric tunables live in config/defaults.toml, NOT here (CANONICAL §12.12).

# ─────────────── Claude / Anthropic (the Agent SDK) ───────────────
# Pick ONE auth mode (all three are supported). API key is simplest for V0.
ANTHROPIC_API_KEY=                 # console.anthropic.com → API Keys
# ANTHROPIC_AUTH_TOKEN=            # alt: OAuth token mode
# CLAUDE_CODE_USE_VERTEX=1         # alt: Vertex mode (+ GCP Vertex config)

# Model seats — REAL ids only (CANONICAL §12.12). These override libs/llm/routing.py.
PROXY_MODEL_SCRIBE=claude-haiku-4-5
PROXY_MODEL_SCRIBE_CLOSE=claude-haiku-4-5
PROXY_MODEL_GATE=claude-haiku-4-5
PROXY_MODEL_QUALITY_GATE=claude-haiku-4-5
PROXY_MODEL_ANSWER=claude-sonnet-4-6
PROXY_MODEL_ORCHESTRATOR=claude-sonnet-4-6
PROXY_MODEL_WORKROOM=claude-sonnet-4-6
PROXY_MODEL_BIG_BUILD=claude-opus-4-8
PROXY_MAX_INFLIGHT_LLM=16          # per-host libs/llm semaphore (distinct from per-meeting 3–5)

# ─────────────── Database — Cloud SQL Postgres 15 ───────────────
# local dev: a plain local/Docker Postgres. prod: Cloud SQL Auth Proxy over a Unix socket (no app-side SSL).
DATABASE_URL=                      # e.g. postgresql://proxy:proxy@localhost:5432/proxy

# ─────────────── Session & user auth ───────────────
SESSION_SECRET=                    # `openssl rand -hex 32`   (required in prod)
GOOGLE_CLIENT_ID=                  # GCP console → APIs & Services → Credentials → OAuth 2.0 Client (Web)
GOOGLE_CLIENT_SECRET=              #   authorized redirect URI: https://<your-domain>/auth/callback

# ─────────────── GCP / storage ───────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1             # keep consistent everywhere (Cloud Run, SQL, GCS, Artifact Registry)
GCS_BUCKET=                        # notes/artifacts bucket — MUST enable Object Versioning
# GOOGLE_APPLICATION_CREDENTIALS=  # LOCAL ONLY: path to a service-account json (never commit). Leave UNSET
                                   #   if using `gcloud auth application-default login` (ADC) — it overrides ADC.

# ─────────────── Transport — Recall + STT/TTS ───────────────
RECALL_API_KEY=                    # recall.ai region dashboard → Developers → API Keys & Secrets (header: Authorization: Token <key>)
RECALL_REGION=us-east-1            # Recall regions are ISOLATED — must match where the key + BYOK paste live
RECALL_WORKSPACE_VERIFICATION_SECRET=   # same page — verifies inbound Recall webhooks
ASSEMBLYAI_API_KEY=                # assemblyai.com — BYOK: ALSO paste this key into the Recall Transcription dashboard, PER REGION
CARTESIA_API_KEY=                  # cartesia.ai — Sonic 3 TTS (model id sonic-3.5; needs X-API-Key + Cartesia-Version header)

# ─────────────── Sandbox ───────────────
E2B_API_KEY=                       # e2b.dev — per-meeting Workroom sandbox

# ─────────────── Connector auth — end-user GitHub via Nango ───────────────
NANGO_SECRET_KEY=                  # Nango (self-host or cloud) — holds the end-user GitHub App grant
NANGO_HOST=                        # e.g. https://api.nango.dev  or your self-host URL

# ─────────────── GitHub App (platform credential — prod: Secret Manager, not here) ───────────────
GITHUB_APP_ID=                     # GitHub App → General → App ID (numeric)
GITHUB_APP_CLIENT_ID=              # GitHub App → General → Client ID (Iv1…/Iv23…) — Nango needs this
GITHUB_APP_CLIENT_SECRET=          # GitHub App → General → Generate client secret — Nango needs this
GITHUB_APP_PRIVATE_KEY_PATH=       # LOCAL: path to the App's .pem private key (never commit); also pasted into Nango
GITHUB_WEBHOOK_SECRET=             # `openssl rand -hex 32` — set identically in the App's webhook config

# ─────────────── Per-domain credential encryption (AES-256-GCM, one key PER integration domain) ───────────────
# One per domain so a single leak's blast radius stays bounded (Doc 00 §7).
AES_KEY_RECALL=                    # `openssl rand -hex 32`
AES_KEY_STT=                       # `openssl rand -hex 32`
AES_KEY_CALENDAR=                  # `openssl rand -hex 32`

# ─────────────── Observability (optional) ───────────────
# SENTRY_DSN=                      # sentry.io — errors (one import, all services)
# LANGFUSE_PUBLIC_KEY=             # scaffold is wired but INERT in V0 (keys unset); turn on in the first cloud env
# LANGFUSE_SECRET_KEY=
