# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.mutmut-cache

# OS
.DS_Store

# Secrets / local env (never commit)
.env
.env.local
*.key
*.pem
secrets.local.*

# Cloud / IaC credentials & state (never commit)
*-sa.json
gcp-*.json
service-account*.json
application_default_credentials.json
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!example.tfvars
crash.log

# Build loop runtime output
runner.log

# Pre-existing artifacts (not part of build)
proxy-overnight-loop.zip
proxy/
fixtures/estate/
state/
fixtures/estates/**/clone/
proxy.bundle

# Orchestrator runtime logs (grow continuously; never commit)
orchestrator/run.log
orchestrator/console.log

# Orchestrator run-pinning markers (purely local; must never be committed/pushed,
# or a pull would carry another run's pin/permission state)
orchestrator/state/run.sha
orchestrator/state/ALLOW_PULL
orchestrator/STOP
